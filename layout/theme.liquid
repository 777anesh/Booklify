<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% render 'css-variables' %}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'base.css' | asset_url | stylesheet_tag }}

    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body class="template-{{ template.name }}">
    <a class="visually-hidden" href="#MainContent">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}
    {% comment %} Category strip sits directly below the site header (see sections/header.liquid for `</header>`). {% endcomment %}
    {% section 'category-strip' %}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'cart-drawer' %}

    <script src="{{ 'base.js' | asset_url }}" defer></script>
  </body>
</html>
