{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign mf_sub = settings.metafield_subtitle_key | split: '.'
  assign mf_rating = settings.metafield_rating_key | split: '.'
  assign mf_rc = settings.metafield_rating_count_key | split: '.'
  assign mf_sold = settings.metafield_sold_count_key | split: '.'

  assign subtitle = product.metafields[mf_sub[0]][mf_sub[1]]
  assign rating = product.metafields[mf_rating[0]][mf_rating[1]]
  assign rating_count = product.metafields[mf_rc[0]][mf_rc[1]]
  assign sold_count = product.metafields[mf_sold[0]][mf_sold[1]]

  assign save_pct = 0
  if product.compare_at_price > product.price
    assign diff = product.compare_at_price | minus: product.price
    assign save_pct = diff | times: 100 | divided_by: product.compare_at_price
  endif

  assign inv = current_variant.inventory_quantity
  assign stock_pct = inv | times: 5
-%}
{%- capture price_formatted -%}
  {{- product.price | money -}}
{%- endcapture -%}

<div class="main-product" data-main-product data-section-id="{{ section.id }}" {{ section.shopify_attributes }}>
  {% render 'breadcrumb', collection_obj: collection %}

  <div class="container">
    <div class="main-product__grid">
      <div class="main-product__media">
        <div class="main-product__stage">
          {%- if product.tags contains 'limited-edition' -%}
            <span class="main-product__badge main-product__badge--left badge badge--dark">{{ 'products.badges.limited_edition' | t }}</span>
          {%- endif -%}

          {%- if product.compare_at_price > product.price -%}
            <span class="main-product__badge main-product__badge--right badge badge--accent">{{ 'products.save_percent' | t: percent: save_pct }}</span>
          {%- endif -%}

          {%- if product.featured_media -%}
            <div class="main-product__main-image" data-main-image>
              {{ product.featured_media | image_url: width: 1600 | image_tag: loading: 'eager', fetchpriority: 'high', alt: product.featured_media.alt | default: product.title }}
            </div>
          {%- endif -%}

          {%- if product.media.size > 1 -%}
            <div class="main-product__thumbs" role="tablist" aria-label="{{ 'products.media_thumbs' | t }}">
              {%- for media in product.media limit: 8 -%}
                <button
                  type="button"
                  class="main-product__thumb{% if forloop.first %} is-active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-src="{{ media | image_url: width: 1600 }}"
                  aria-label="{{ 'products.media_go_to' | t: index: forloop.index }}"
                >
                  {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: media.alt | default: product.title }}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="main-product__info">
        <p class="main-product__kicker text-secondary">
          {{ product.type | default: section.settings.kicker_fallback }}
          {%- if collection -%}
            · {{ collection.title }}
          {%- endif -%}
        </p>

        <h1 class="main-product__title">{{ product.title }}</h1>

        {%- if subtitle != blank -%}
          <p class="main-product__subtitle text-secondary">{{ subtitle.value | default: subtitle }}</p>
        {%- endif -%}

        <div class="main-product__rating text-secondary">
          <span class="main-product__stars" aria-hidden="true">★★★★★</span>
          {%- if rating != blank -%}
            <span>{{ rating.value | default: rating }}</span>
          {%- endif -%}
          {%- if rating_count != blank -%}
            <a href="#reviews">({{ rating_count.value | default: rating_count }} {{ 'products.reviews_word' | t }})</a>
          {%- endif -%}
          {%- if sold_count != blank -%}
            <span>· {{ sold_count.value | default: sold_count }} {{ 'products.sold' | t }}</span>
          {%- endif -%}
        </div>

        <div class="main-product__price-row">
          <span class="main-product__price">{{ product.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <s class="text-muted">{{ product.compare_at_price | money }}</s>
            <span class="badge badge--accent">{{ 'products.save_percent' | t: percent: save_pct }}</span>
          {%- endif -%}
        </div>

        {%- if section.settings.show_sale_note -%}
          <p class="text-danger">{{ section.settings.sale_note }}</p>
        {%- endif -%}

        {%- if settings.enable_urgency and current_variant.inventory_management -%}
          {%- if inv > 0 and inv <= settings.selling_fast_threshold -%}
            <p class="text-danger">{{ 'products.only_left' | t: count: inv }}</p>
            <div class="stock-bar" aria-hidden="true">
              <span style="width: {{ stock_pct }}%;"></span>
            </div>
            <p class="text-secondary text-muted">{{ 'products.stock_note' | t: percent: stock_pct }}</p>
          {%- endif -%}
        {%- endif -%}

        {%- capture product_form_id -%}product-form-{{ section.id }}{%- endcapture -%}
        {% form 'product', product, id: product_form_id, class: 'main-product__form' %}
          {%- unless product.has_only_default_variant -%}
            <div class="main-product__variants">
              {%- if product.options_with_values.size == 1 -%}
                {%- assign opt = product.options_with_values | first -%}
                <div class="main-product__option-label">{{ opt.name }}</div>
                <div class="main-product__pills" data-variant-pills>
                  {%- for value in opt.values -%}
                    {%- assign var_for_value = nil -%}
                    {%- for variant in product.variants -%}
                      {%- if variant.option1 == value -%}
                        {%- assign var_for_value = variant -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- if var_for_value -%}
                      <button
                        type="button"
                        class="main-product__pill{% if var_for_value == current_variant %} is-active{% endif %}{% unless var_for_value.available %} is-disabled{% endunless %}"
                        data-variant-id="{{ var_for_value.id }}"
                        {% unless var_for_value.available %}
                          disabled
                        {% endunless %}
                      >
                        {{ value }}
                      </button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <select class="visually-hidden" name="id" data-variant-select>
                  {%- for variant in product.variants -%}
                    <option
                      value="{{ variant.id }}"
                      {% if variant == current_variant %}
                        selected
                      {% endif %}
                      {% unless variant.available %}
                        disabled
                      {% endunless %}
                    >
                      {{ variant.title }}
                    </option>
                  {%- endfor -%}
                </select>
              {%- else -%}
                <label class="visually-hidden" for="VariantSelect-{{ section.id }}">{{ 'products.variant' | t }}</label>
                <select id="VariantSelect-{{ section.id }}" name="id" data-variant-select>
                  {%- for variant in product.variants -%}
                    <option
                      value="{{ variant.id }}"
                      {% if variant == current_variant %}
                        selected
                      {% endif %}
                      {% unless variant.available %}
                        disabled
                      {% endunless %}
                    >
                      {{ variant.title }} — {{ variant.price | money }}
                    </option>
                  {%- endfor -%}
                </select>
              {%- endif -%}
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- endunless -%}

          <div class="main-product__qty-row">
            <div class="qty" data-qty>
              <button type="button" data-qty-dec aria-label="{{ 'products.qty_decrease' | t }}">−</button>
              <input type="number" name="quantity" min="1" value="1" data-qty-input>
              <button type="button" data-qty-inc aria-label="{{ 'products.qty_increase' | t }}">+</button>
            </div>

            <button type="submit" name="add" class="btn btn--primary btn--block js-main-atc">
              {{ 'products.add_to_bag_money' | t: price: price_formatted }}
            </button>
          </div>

          {{ form | payment_button }}

          <div class="main-product__trustline text-secondary">
            {{ section.settings.trust_line }}
          </div>

          {%- if section.blocks.size > 0 -%}
            <ul class="main-product__bullets">
              {%- for block in section.blocks -%}
                {%- if block.type == 'bullet' -%}
                  <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>

  <div class="sticky-atc" data-sticky-atc aria-hidden="true">
    <div class="sticky-atc__inner container">
      <div class="sticky-atc__product">
        {%- if product.featured_image -%}
          {{ product.featured_image | image_url: width: 144 | image_tag: loading: 'lazy', alt: product.title, class: 'sticky-atc__thumb' }}
        {%- endif -%}
        <div>
          <div class="sticky-atc__title">{{ product.title }}</div>
          <div class="sticky-atc__price">
            {%- if product.compare_at_price > product.price -%}
              <s class="text-muted">{{ product.compare_at_price | money }}</s>
            {%- endif -%}
            <strong>{{ product.price | money }}</strong>
            {%- if product.compare_at_price > product.price -%}
              <span class="badge badge--accent">{{ 'products.save_percent' | t: percent: save_pct }}</span>
            {%- endif -%}
          </div>
          {%- if settings.enable_urgency and current_variant.inventory_management and inv > 0 and inv <= settings.selling_fast_threshold -%}
            <div class="text-danger">{{ 'products.only_left' | t: count: inv }}</div>
          {%- endif -%}
        </div>
      </div>
      <div class="sticky-atc__trust text-secondary">{{ section.settings.sticky_trust_text }}</div>
      <button type="button" class="btn btn--primary sticky-atc__btn" data-sticky-add data-variant-id="{{ current_variant.id }}">
        {{ 'products.add_to_bag_money' | t: price: price_formatted }}
      </button>
    </div>
  </div>
</div>

<script src="{{ 'section-main-product.js' | asset_url }}" defer></script>

{% stylesheet %}
  .main-product__grid {
    display: grid;
    gap: clamp(18px, 4vw, 36px);
    padding-bottom: 32px;
  }

  @media (min-width: 990px) {
    .main-product__grid {
      grid-template-columns: 1.05fr 0.95fr;
      align-items: start;
    }
  }

  .main-product__stage {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
  }

  .main-product__main-image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: transform 700ms ease;
  }

  .main-product__stage:hover .main-product__main-image img {
    transform: scale(1.04);
  }

  .main-product__badge {
    position: absolute;
    top: 12px;
    z-index: 2;
  }

  .main-product__badge--left {
    left: 12px;
  }

  .main-product__badge--right {
    right: 12px;
  }

  .main-product__thumbs {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
    padding: 10px;
    border-top: 1px solid var(--color-border);
    background: var(--color-page-bg);
  }

  .main-product__thumb {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    background: transparent;
  }

  .main-product__thumb.is-active {
    outline: 2px solid var(--color-cta-bg);
    outline-offset: 1px;
  }

  .main-product__thumb img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .main-product__kicker {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 11px;
    font-weight: 500;
    margin-bottom: 10px;
  }

  .main-product__title {
    font-size: clamp(26px, 3.4vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
    font-weight: 500;
  }

  .main-product__subtitle {
    font-size: 15px;
    margin-bottom: 12px;
  }

  .main-product__rating {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 14px;
    font-size: 13px;
  }

  .main-product__stars {
    color: var(--color-accent);
    letter-spacing: 1px;
  }

  .main-product__price-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: baseline;
    margin-bottom: 10px;
  }

  .main-product__price {
    font-size: 28px;
    font-weight: 500;
  }

  .stock-bar {
    height: 8px;
    background: #f0f0f0;
    border-radius: 999px;
    overflow: hidden;
    margin: 8px 0;
  }

  .stock-bar span {
    display: block;
    height: 100%;
    background: var(--color-accent);
  }

  .main-product__form {
    margin-top: 16px;
    display: grid;
    gap: 14px;
  }

  .main-product__option-label {
    font-weight: 500;
    font-size: 13px;
    margin-bottom: 8px;
  }

  .main-product__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 10px;
  }

  .main-product__pill {
    border: 1px solid var(--color-border);
    background: var(--color-page-bg);
    padding: 10px 12px;
    border-radius: var(--radius-pill);
    cursor: pointer;
    font-weight: 500;
  }

  .main-product__pill.is-active {
    border-color: var(--color-cta-bg);
    box-shadow: 0 0 0 1px var(--color-cta-bg);
  }

  .main-product__pill.is-disabled {
    opacity: 0.45;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  .main-product__qty-row {
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 750px) {
    .main-product__qty-row {
      grid-template-columns: 160px 1fr;
      align-items: center;
    }
  }

  .qty {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 8px 10px;
    justify-content: space-between;
  }

  .qty button {
    border: 0;
    background: transparent;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
  }

  .qty input {
    width: 44px;
    border: 0;
    text-align: center;
    font-weight: 500;
  }

  .main-product__trustline {
    font-size: 13px;
  }

  .main-product__bullets {
    margin: 0;
    padding-left: 18px;
    color: var(--color-text-secondary);
    display: grid;
    gap: 8px;
    font-size: 14px;
  }

  .sticky-atc {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 90;
    min-height: 60px;
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    border-top: 0.5px solid var(--color-border);
    transform: translateY(110%);
    transition: transform var(--transition-base);
    box-sizing: border-box;
    padding-bottom: env(safe-area-inset-bottom);
  }

  .sticky-atc.is-visible {
    transform: translateY(0);
  }

  .sticky-atc__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    width: 100%;
    padding: 0 40px;
    min-height: 60px;
    box-sizing: border-box;
  }

  .sticky-atc__product {
    display: flex;
    gap: 10px;
    align-items: center;
    min-width: 0;
    flex: 1;
  }

  .sticky-atc__thumb {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    object-fit: cover;
    border: 0.5px solid var(--color-border);
    flex-shrink: 0;
  }

  .sticky-atc__title {
    font-weight: 500;
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-atc__price {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 12px;
    font-weight: 400;
  }

  .sticky-atc__trust {
    font-size: 12px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sticky-atc__btn {
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 500;
    border-radius: 10px;
    white-space: nowrap;
    min-height: 0;
    margin-left: auto;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .sticky-atc__inner {
      padding: 0 16px;
      gap: 10px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_product.name",
  "settings": [
    {
      "type": "text",
      "id": "kicker_fallback",
      "label": "t:sections.main_product.settings.kicker_fallback.label",
      "default": "Collection"
    },
    {
      "type": "checkbox",
      "id": "show_sale_note",
      "label": "t:sections.main_product.settings.sale_note_enable.label",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_note",
      "label": "t:sections.main_product.settings.sale_note.label",
      "default": "Sale price — offer ends today"
    },
    {
      "type": "textarea",
      "id": "trust_line",
      "label": "t:sections.main_product.settings.trust_line.label",
      "default": "30-day returns · Free shipping · Secure checkout · Ships today"
    },
    {
      "type": "text",
      "id": "sticky_trust_text",
      "label": "t:sections.main_product.settings.sticky_trust.label",
      "default": "Free shipping"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "t:sections.main_product.blocks.bullet.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.main_product.blocks.bullet.settings.text.label",
          "default": "Brand new, factory sealed — never opened or used"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_product.presets.name",
      "blocks": [
        { "type": "bullet" },
        { "type": "bullet" },
        { "type": "bullet" },
        { "type": "bullet" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
