{%- liquid
  assign menu = section.settings.category_menu
  if menu == blank or menu.links.size == 0
    assign menu = linklists['category-navigation']
  endif
  if menu == blank or menu.links.size == 0
    assign menu = linklists['main-menu']
  endif
-%}

{%- if menu != blank and menu.links.size > 0 -%}
  <nav
    class="category-strip category-strip--sticky"
    aria-label="Browse by category"
    data-category-strip
    {{ section.shopify_attributes }}
  >
    <div class="container category-strip__inner">
      {% for link in menu.links %}
        <a
          href="{{ link.url }}"
          class="category-strip__item{% if link.active %} category-strip__item--active{% endif %}"
          aria-current="{% if link.active %}page{% else %}false{% endif %}"
        >
          {{ link.title }}
        </a>
        {% unless forloop.last %}
          <span class="category-strip__sep" aria-hidden="true">|</span>
        {% endunless %}
      {% endfor %}
    </div>
  </nav>

  <script src="{{ 'section-category-strip.js' | asset_url }}" defer></script>
{%- endif -%}

{% stylesheet %}
  .category-strip {
    height: 40px;
    display: flex;
    align-items: stretch;
    padding: 0;
    border-bottom: 0.5px solid var(--color-border);
    background: var(--color-page-bg);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .category-strip::-webkit-scrollbar {
    display: none;
  }

  .category-strip--sticky {
    position: sticky;
    z-index: 99;
    top: var(--header-height);
  }

  .category-strip__inner {
    display: flex;
    align-items: stretch;
    white-space: nowrap;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }

  .category-strip__item {
    display: flex;
    align-items: center;
    padding: 0 14px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .category-strip__item:hover,
  .category-strip__item--active {
    color: var(--color-text-primary);
    border-bottom-color: currentColor;
  }

  .category-strip__sep {
    display: flex;
    align-items: center;
    font-size: 12px;
    opacity: 0.3;
    padding: 0 2px;
    user-select: none;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .category-strip {
      padding: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category strip",
  "settings": [
    {
      "type": "link_list",
      "id": "category_menu",
      "label": "Category menu"
    }
  ]
}
{% endschema %}
