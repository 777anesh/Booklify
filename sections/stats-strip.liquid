    },
    {
      "type": "select",
      "id": "stat_3_icon",
      "label": "t:sections.stats_strip.settings.stat_3_icon.label",
      "default": "truck",
      "options": [
        { "value": "users", "label": "t:sections.stats_strip.icons.users" },
        { "value": "star", "label": "t:sections.stats_strip.icons.star" },
        { "value": "truck", "label": "t:sections.stats_strip.icons.truck" },
        { "value": "refresh", "label": "t:sections.stats_strip.icons.refresh" }
      ]
    },
    {
      "type": "text",
      "id": "stat_4_number",
      "label": "t:sections.stats_strip.settings.stat_4_number.label",
