        { "value": "truck", "label": "t:sections.stats_strip.icons.truck" },
        { "value": "refresh", "label": "t:sections.stats_strip.icons.refresh" }
      ]
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "t:sections.stats_strip.settings.stat_3_number.label",
      "default": "Same day"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "t:sections.stats_strip.settings.stat_3_label.label",
