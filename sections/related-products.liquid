{%- liquid
  assign coll = section.settings.related_collection | default: collection | default: product.collections.first
-%}

<section class="section related-products" {{ section.shopify_attributes }}>
  <div class="container">
    <header class="section__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- if coll != blank -%}
      <div class="related-products__grid">
        {%- assign shown = 0 -%}
        {%- for p in coll.products -%}
          {%- if p.id == product.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- if shown >= section.settings.products_to_show -%}
            {%- break -%}
          {%- endif -%}
          <div>
            {% render 'product-card', product: p, show_quick_add: false, enable_selling_fast: true %}
          </div>
          {%- assign shown = shown | plus: 1 -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="text-secondary">{{ 'sections.onboarding.collection' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .related-products__grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  @media (min-width: 990px) {
    .related-products__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.related_products.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.related_products.settings.heading.label",
      "default": "You might also like"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.related_products.settings.subheading.label",
      "default": "From the same collection"
    },
    {
      "type": "collection",
      "id": "related_collection",
      "label": "t:sections.related_products.settings.collection.label",
      "info": "t:sections.related_products.settings.collection.info"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 8,
      "step": 1,
      "label": "t:sections.related_products.settings.limit.label",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "t:sections.related_products.presets.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
