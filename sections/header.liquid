{%- liquid
  assign logo_text = section.settings.logo_text | default: settings.brand_name
-%}

<header
  class="site-header"
  data-site-header
  data-enable-sticky="{{ section.settings.enable_sticky_header }}"
  {{ section.shopify_attributes }}
>
  <div class="site-header__inner container">
    <button type="button" class="site-header__icon site-header__icon--menu" data-open-nav aria-label="{{ 'general.accessibility.open_menu' | t }}">
      {% render 'icon-menu' %}
    </button>

    <a class="site-header__logo" href="{{ routes.root_url }}" style="--logo-max: {{ section.settings.logo_max_width }}px;">
      {%- if section.settings.logo_image != blank -%}
        {{ section.settings.logo_image | image_url: width: 600 | image_tag: alt: logo_text, loading: 'eager' }}
      {%- else -%}
        <span class="site-header__logo-text">{{ logo_text }}</span>
      {%- endif -%}
    </a>

    <nav class="site-header__nav" aria-label="{{ 'general.accessibility.main_navigation' | t }}">
      {%- if section.settings.menu != blank -%}
        <ul class="site-header__menu">
          {%- for link in section.settings.menu.links -%}
            <li>
              <a href="{{ link.url }}" class="site-header__menu-link{% if link.active %} is-active{% endif %}">
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>

    <div class="site-header__actions">
      <button type="button" class="site-header__icon" data-open-search aria-label="{{ 'general.search.search' | t }}">
        {% render 'icon-search' %}
      </button>

      <a class="site-header__icon site-header__cart" href="{{ routes.cart_url }}" data-cart-open aria-label="{{ 'cart.title' | t }}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        <span class="site-header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  <dialog class="site-header__dialog" data-nav-dialog aria-label="{{ 'general.accessibility.menu' | t }}">
    <div class="site-header__dialog-panel">
      <div class="site-header__dialog-head">
        <strong>{{ logo_text }}</strong>
        <button type="button" class="site-header__icon" data-close-nav aria-label="{{ 'general.accessibility.close' | t }}">
          {% render 'icon-close' %}
        </button>
      </div>
      {%- if section.settings.menu != blank -%}
        <ul class="site-header__dialog-menu">
          {%- for link in section.settings.menu.links -%}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </dialog>

  <dialog class="site-header__search" data-search-dialog aria-label="{{ 'general.search.search' | t }}">
    <div class="site-header__search-panel">
      <button type="button" class="site-header__icon" data-close-search aria-label="{{ 'general.accessibility.close' | t }}">
        {% render 'icon-close' %}
      </button>
      <form action="{{ routes.search_url }}" method="get" role="search" class="site-header__search-form">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'search.placeholder' | t }}" autocomplete="off">
        <button type="submit" class="btn btn--primary">{{ 'search.submit' | t }}</button>
      </form>
    </div>
  </dialog>
</header>

<script src="{{ 'section-header.js' | asset_url }}" defer></script>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 110;
    background: var(--color-page-bg);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .site-header--sticky {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    min-height: var(--header-height);
  }

  .site-header__logo {
    justify-self: center;
    text-decoration: none;
    color: inherit;
    max-width: var(--logo-max, 140px);
  }

  .site-header__logo img {
    width: 100%;
    height: auto;
  }

  .site-header__logo-text {
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.02em;
  }

  .site-header__nav {
    justify-self: center;
  }

  .site-header__menu {
    list-style: none;
    display: flex;
    gap: 18px;
    padding: 0;
    margin: 0;
  }

  .site-header__menu-link {
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 0;
    border-bottom: 2px solid transparent;
  }

  .site-header__menu-link:hover,
  .site-header__menu-link.is-active {
    color: var(--color-text-primary);
    border-color: var(--color-cta-bg);
  }

  .site-header__actions {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .site-header__icon {
    border: 0;
    background: transparent;
    padding: 10px;
    cursor: pointer;
    color: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .site-header__icon svg {
    width: 22px;
    height: 22px;
  }

  .site-header__cart {
    position: relative;
    text-decoration: none;
    color: inherit;
  }

  .site-header__cart-count {
    position: absolute;
    top: 4px;
    right: 2px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    background: var(--color-cta-bg);
    color: var(--color-cta-text);
    font-size: 11px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .site-header__icon--menu {
    justify-self: start;
  }

  @media (min-width: 990px) {
    .site-header__icon--menu {
      display: none;
    }

    .site-header__inner {
      grid-template-columns: 1fr auto 1fr;
    }

    .site-header__logo {
      justify-self: start;
    }

    .site-header__nav {
      justify-self: center;
    }

    .site-header__actions {
      justify-self: end;
    }
  }

  @media (max-width: 989px) {
    .site-header__nav {
      display: none;
    }

    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .site-header__logo {
      justify-self: center;
    }
  }

  .site-header__dialog,
  .site-header__search {
    padding: 0;
    border: 0;
    width: min(520px, 100%);
    max-height: 100%;
  }

  .site-header__dialog::backdrop,
  .site-header__search::backdrop {
    background: rgba(0, 0, 0, 0.45);
  }

  .site-header__dialog-panel {
    padding: 18px;
    height: 100%;
    background: var(--color-page-bg);
  }

  .site-header__dialog-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .site-header__dialog-menu {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }

  .site-header__dialog-menu a {
    text-decoration: none;
    color: inherit;
    font-size: 18px;
    font-weight: 600;
  }

  .site-header__search-panel {
    padding: 18px;
    background: var(--color-page-bg);
    display: grid;
    gap: 12px;
  }

  .site-header__search-form {
    display: grid;
    gap: 10px;
  }

  .site-header__search-form input {
    width: 100%;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "t:sections.header.settings.logo_image.label"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:sections.header.settings.logo_text.label",
      "default": "Booklify"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 60,
      "max": 240,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.logo_max_width.label",
      "default": 140
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header",
      "label": "t:sections.header.settings.sticky.label",
      "default": true
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label"
    }
  ]
}
{% endschema %}
