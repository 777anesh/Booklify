{% comment %}
  404 page with configurable copy and dual CTAs.
{% endcomment %}

<section class="section page-not-found" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="page-not-found__card">
      <p class="section__label">{{ section.settings.eyebrow }}</p>
      <h1 class="page-not-found__title">{{ section.settings.heading }}</h1>
      <p class="page-not-found__message text-secondary">{{ section.settings.message }}</p>
      <div class="page-not-found__actions">
        <a class="btn btn--primary" href="{{ section.settings.primary_url | default: routes.all_products_collection_url }}">
          {{ section.settings.primary_text }}
        </a>
        {%- if section.settings.secondary_text != blank and section.settings.secondary_url != blank -%}
          <a class="btn btn--ghost" href="{{ section.settings.secondary_url }}">{{ section.settings.secondary_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .page-not-found__card {
    max-width: 36rem;
    margin: 0 auto;
    text-align: center;
    padding: clamp(32px, 6vw, 56px) clamp(20px, 4vw, 32px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-page-bg);
  }

  .page-not-found__title {
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 500;
    margin-bottom: 12px;
  }

  .page-not-found__message {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .page-not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.page_not_found.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "404"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.page_not_found.settings.heading.label",
      "default": "We can't find that page"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "t:sections.page_not_found.settings.message.label",
      "default": "The link may be broken or the page may have been removed. Head back to the shop to keep browsing."
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "t:sections.page_not_found.settings.primary_text.label",
      "default": "Back to shopping"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "t:sections.page_not_found.settings.primary_url.label"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "t:sections.page_not_found.settings.secondary_text.label",
      "default": "View all collections"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "t:sections.page_not_found.settings.secondary_url.label"
    }
  ]
}
{% endschema %}
