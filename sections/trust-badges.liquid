<section class="section section--tight trust-badges surface-muted" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="trust-badges__grid">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'item' -%}
          <div class="trust-badges__item trust-item text-center" {{ block.shopify_attributes }}>
            <div class="trust-badges__icon trust-item__icon" aria-hidden="true">
              {% render 'icon-trust', name: block.settings.badge_icon %}
            </div>
            <div class="trust-badges__title trust-item__title">{{ block.settings.badge_title }}</div>
            <div class="trust-badges__subtitle trust-item__subtitle text-secondary">{{ block.settings.badge_subtitle }}</div>
          </div>
      {%- endcase -%}
    {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .trust-badges__grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    padding: 24px 0;
  }

  .trust-badges__item,
  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 6px;
    padding: 0;
  }

  .trust-badges__icon,
  .trust-item__icon {
    display: flex;
    justify-content: center;
    font-size: 22px;
    color: var(--color-accent-dark);
  }

  .trust-badges__icon svg,
  .trust-item__icon svg {
    width: 22px;
    height: 22px;
  }

  .trust-badges__title,
  .trust-item__title {
    font-weight: 500;
    font-size: 13px;
    margin: 0;
  }

  .trust-badges__subtitle,
  .trust-item__subtitle {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.45;
  }

  @media (max-width: 768px) {
    .trust-badges__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 20px 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.trust_badges.name",
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.trust_badges.blocks.item.name",
      "settings": [
        {
          "type": "select",
          "id": "badge_icon",
          "label": "t:sections.trust_badges.blocks.item.settings.icon.label",
          "default": "refresh",
          "options": [
            { "value": "refresh", "label": "t:icons.refresh" },
            { "value": "package", "label": "t:icons.package" },
            { "value": "truck", "label": "t:icons.truck" },
            { "value": "lock", "label": "t:icons.lock" },
            { "value": "shield", "label": "t:icons.shield" },
            { "value": "star", "label": "t:icons.star" }
          ]
        },
        {
          "type": "text",
          "id": "badge_title",
          "label": "t:sections.trust_badges.blocks.item.settings.title.label",
          "default": "30-day returns"
        },
        {
          "type": "text",
          "id": "badge_subtitle",
          "label": "t:sections.trust_badges.blocks.item.settings.subtitle.label",
          "default": "No stress if it is not a perfect match."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.trust_badges.presets.name",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
