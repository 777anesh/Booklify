[
  {
    "name": "theme_info",
    "theme_name": "Booklify",
    "theme_version": "1.0.0",
    "theme_author": "Booklify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "header",
        "content": "Brand"
      },
      {
        "type": "text",
        "id": "brand_name",
        "label": "Store name",
        "default": "Booklify"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color",
        "default": "#EF9F27"
      },
      {
        "type": "color",
        "id": "color_accent_dark",
        "label": "Accent text on light surfaces",
        "default": "#633806"
      },
      {
        "type": "color",
        "id": "color_cta_bg",
        "label": "Primary button background",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_cta_text",
        "label": "Primary button text",
        "default": "#f5f5f5"
      },
      {
        "type": "color",
        "id": "color_page_bg",
        "label": "Page background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface / muted background",
        "default": "#F1EFE8"
      },
      {
        "type": "color",
        "id": "color_text_primary",
        "label": "Primary text",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary text",
        "default": "#5a5a5a"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted text",
        "default": "#9a9a9a"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Borders",
        "default": "#e5e5e5"
      },
      {
        "type": "color",
        "id": "color_announcement_bg",
        "label": "Announcement bar background (light style)",
        "default": "#FAEEDA"
      },
      {
        "type": "color",
        "id": "color_announcement_text",
        "label": "Announcement bar text (light style)",
        "default": "#633806"
      },
      {
        "type": "range",
        "id": "container_max_width",
        "min": 960,
        "max": 1400,
        "step": 8,
        "unit": "px",
        "label": "Max content width",
        "default": 1200
      },
      {
        "type": "range",
        "id": "page_padding",
        "min": 12,
        "max": 48,
        "step": 2,
        "unit": "px",
        "label": "Horizontal page padding",
        "default": 24
      }
    ]
  },
  {
    "name": "Offers and urgency",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_urgency",
        "label": "Enable urgency features",
        "default": true
      },
      {
        "type": "text",
        "id": "sale_end_datetime",
        "label": "Sale end date/time (ISO 8601)",
        "default": "2099-12-31T23:59:59",
        "info": "Example: 2026-12-31T23:59:59-05:00. Used when a section does not override the date. Far-future default means no sale end until you set a real date."
      },
      {
        "type": "number",
        "id": "selling_fast_threshold",
        "label": "Selling fast inventory threshold",
        "default": 20
      }
    ]
  },
  {
    "name": "Shipping and trust",
    "settings": [
      {
        "type": "text",
        "id": "free_shipping_threshold",
        "label": "Free shipping minimum (shop money units)",
        "default": "35",
        "info": "Enter a number in your store currency (e.g. 35 for $35)."
      },
      {
        "type": "text",
        "id": "shipping_cutoff_time",
        "label": "Same-day shipping cutoff label",
        "default": "2PM"
      },
      {
        "type": "text",
        "id": "return_window_days",
        "label": "Return window (days)",
        "default": "30"
      }
    ]
  },
  {
    "name": "Product metafields",
    "settings": [
      {
        "type": "text",
        "id": "metafield_author_key",
        "label": "Author line metafield (namespace.key)",
        "default": "book.author",
        "info": "Example: book.author or custom.designer"
      },
      {
        "type": "text",
        "id": "metafield_subtitle_key",
        "label": "Subtitle metafield (namespace.key)",
        "default": "book.subtitle"
      },
      {
        "type": "text",
        "id": "metafield_whats_included_key",
        "label": "What's included metafield (namespace.key)",
        "default": "book.whats_included"
      },
      {
        "type": "text",
        "id": "metafield_publisher_key",
        "label": "Publisher details metafield (namespace.key)",
        "default": "book.publisher_details"
      },
      {
        "type": "text",
        "id": "metafield_rating_key",
        "label": "Review rating metafield (namespace.key)",
        "default": "reviews.rating"
      },
      {
        "type": "text",
        "id": "metafield_rating_count_key",
        "label": "Review count metafield (namespace.key)",
        "default": "reviews.rating_count"
      },
      {
        "type": "text",
        "id": "metafield_sold_count_key",
        "label": "Sold count metafield (namespace.key)",
        "default": "book.sold_count"
      },
      {
        "type": "text",
        "id": "metafield_selling_fast_key",
        "label": "Selling fast metafield (namespace.key)",
        "default": "booklify.selling_fast"
      }
    ]
  }
]
