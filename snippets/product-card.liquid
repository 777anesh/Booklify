{% doc %}
  Renders a product card for grids.

  @param {object} product - Product object
  @param {boolean} [show_quick_add] - Show quick add button
  @param {boolean} [enable_selling_fast] - Show selling fast badge using inventory threshold
  @param {number} [threshold] - Inventory threshold

  @example
  {% render 'product-card', product: product, show_quick_add: true %}
{% enddoc %}

{%- liquid
  assign mf_parts = settings.metafield_author_key | split: '.'
  assign mf_ns = mf_parts | first
  assign mf_key = mf_parts | last
  assign author_field = product.metafields[mf_ns][mf_key]

  assign sf_parts = settings.metafield_selling_fast_key | split: '.'
  assign sf_ns = sf_parts | first
  assign sf_key = sf_parts | last
  assign selling_fast_meta = product.metafields[sf_ns][sf_key]

  assign current_variant = product.selected_or_first_available_variant
  assign inv = current_variant.inventory_quantity
  assign threshold_num = threshold | default: settings.selling_fast_threshold
-%}

<div class="product-card">
  <div class="product-card__image-wrapper">
    <a href="{{ product.url }}" class="product-card__image-link">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
      {%- else -%}
        <div class="product-card__placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </a>

    {%- unless product.available -%}
      <span class="product-card__badge product-card__badge--soldout">{{ 'products.sold_out' | t }}</span>
    {%- else -%}
      {%- if enable_selling_fast -%}
        {%- assign show_hot = false -%}
        {%- if selling_fast_meta == true or selling_fast_meta.value == true -%}
          {%- assign show_hot = true -%}
        {%- endif -%}
        {%- if current_variant.inventory_management -%}
          {%- if inv > 0 and inv <= threshold_num -%}
            {%- assign show_hot = true -%}
          {%- endif -%}
        {%- endif -%}
        {%- if show_hot -%}
          <span class="product-card__badge product-card__badge--hot">{{ 'products.selling_fast' | t }}</span>
        {%- endif -%}
      {%- endif -%}
    {%- endunless -%}

    {%- if show_quick_add and product.available -%}
      <div class="product-card__quick">
        <button
          type="button"
          class="btn btn--primary btn--block"
          data-add-to-cart
          data-variant-id="{{ current_variant.id }}"
          data-quantity="1"
        >
          {{ 'products.add_to_bag' | t }}
        </button>
      </div>
    {%- endif -%}
  </div>

  <div class="product-card__info">
    {%- liquid
      assign rc_parts = settings.metafield_rating_count_key | split: '.'
      assign rc_ns = rc_parts | first
      assign rc_key = rc_parts | last
      assign rating_count_field = product.metafields[rc_ns][rc_key]
    -%}
    {%- if rating_count_field != blank -%}
      <div class="product-card__stars text-secondary" aria-hidden="true">★★★★★ <span class="text-muted">({{ rating_count_field.value | default: rating_count_field }})</span></div>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    {%- if author_field != blank -%}
      <p class="product-card__author text-secondary">{{ author_field.value | default: author_field }}</p>
    {%- endif -%}

    <div class="product-card__price">
      {%- if product.compare_at_price > product.price -%}
        <s class="text-muted">{{ product.compare_at_price | money }}</s>
      {%- endif -%}
      <span class="product-card__price-current">{{ product.price | money }}</span>
    </div>

    {%- unless show_quick_add -%}
      {%- if product.available -%}
        <button
          type="button"
          class="btn btn--primary btn--block product-card__atc"
          data-add-to-cart
          data-variant-id="{{ current_variant.id }}"
          data-quantity="1"
        >
          {{ 'products.add_to_bag' | t }}
        </button>
      {%- else -%}
        <button type="button" class="btn btn--ghost btn--block" disabled>{{ 'products.sold_out' | t }}</button>
      {%- endif -%}
    {%- endunless -%}
  </div>
</div>

{% stylesheet %}
  .product-card {
    border: 0.5px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--color-page-bg);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .product-card__image-wrapper {
    position: relative;
  }

  .product-card__image-link img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .product-card__placeholder {
    aspect-ratio: 3 / 4;
    background: var(--color-surface);
  }

  .product-card__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 2;
    font-size: 11px;
    font-weight: 500;
    padding: 6px 10px;
    border-radius: var(--radius-pill);
  }

  .product-card__badge--soldout {
    background: #111;
    color: #fff;
  }

  .product-card__badge--hot {
    background: var(--color-accent);
    color: var(--color-accent-dark);
  }

  .product-card__quick {
    position: absolute;
    inset: auto 10px 10px 10px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  @media (hover: hover) {
    .product-card__image-wrapper:hover .product-card__quick {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-card__info {
    padding: 12px;
    display: grid;
    gap: 6px;
    flex: 1;
  }

  .product-card__stars {
    font-size: 12px;
  }

  .product-card__title {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.25;
  }

  .product-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .product-card__author {
    font-size: 12px;
    font-weight: 400;
  }

  .product-card__price {
    display: flex;
    gap: 10px;
    align-items: baseline;
    font-weight: 500;
    font-size: 14px;
  }

  .product-card__price s {
    font-size: 12px;
    font-weight: 400;
  }

  .product-card__atc {
    margin-top: auto;
    font-size: 12px;
    padding: 8px 12px;
    font-weight: 500;
  }

  .product-card__quick .btn {
    font-size: 12px;
    padding: 8px 12px;
    font-weight: 500;
  }
{% endstylesheet %}
