{% doc %}
  Renders trust / utility icons used across sections.

  @param {string} name - One of: refresh, package, truck, lock, shield, star

  @example
  {% render 'icon-trust', name: 'lock' %}
{% enddoc %}

{%- case name -%}
  {%- when 'refresh' -%}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M5 12a7 7 0 0 1 7-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M5 5v6h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  {%- when 'package' -%}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M4 8l8-4 8 4v10l-8 4-8-4V8Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      <path d="M4 8l8 4 8-4M12 12v10" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
  {%- when 'truck' -%}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M3 7h11v8H3V7Zm11 5h3l3 3v2h-6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      <path d="M7 20a2 2 0 1 0 0 .1M17 20a2 2 0 1 0 0 .1" stroke="currentColor" stroke-width="1.6"/>
    </svg>
  {%- when 'lock' -%}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M7 11V8a5 5 0 0 1 10 0v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M6 11h12v9H6V11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
  {%- when 'shield' -%}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M12 3l8 3v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>
  {%- else -%}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <path d="M12 3l2.6 5.3 5.8.8-4.2 4.1 1 5.8L12 16.9 6.8 19l1-5.8L3.6 9.1l5.8-.8L12 3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
    </svg>
{%- endcase -%}
